# BeautyOS - Evolution API para Docker local
# Copia este archivo como evolution-api.env y cambia todas las claves marcadas.

SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# Debe ser exactamente igual a EVOLUTION_API_KEY en .env
AUTHENTICATION_API_KEY=REEMPLAZAR_CON_LA_MISMA_CLAVE_DE_ENV

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution_secret_2026@postgres:5432/evolution?schema=public

REDIS_ENABLED=true
REDIS_URI=redis://redis:6379

WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://host.docker.internal:3000/webhook/evolution
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

CACHE_REDIS_ENABLED=true
CACHE_LOCAL_ENABLED=false

CONFIG_SESSION_PHONE_CLIENT=BeautyOS
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30
